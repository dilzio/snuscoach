ANTHROPIC_API_KEY=your-key-here
# Optional: override DB location (default: ~/.snuscoach/snuscoach.db)
# SNUSCOACH_DB=/absolute/path/to/snuscoach.db

# Optional: LLM call logging.
# SNUSCOACH_LOG=true                              # default true; "false"/"0"/"off" disables
# SNUSCOACH_LOG_DIR=/absolute/path/to/logs        # default ~/.snuscoach/logs
